---
import "../styles/global.css";

const email = "202300130120@mail.sdu.edu.cn";
const github = "https://github.com/SDLSY";

const interests = ["可穿戴计算", "移动感知", "健康计算", "端侧智能", "时序信号识别"];

const projects = [
  {
    id: "vespero",
    eyebrow: "核心项目",
    title: "长庚环 VesperO",
    subtitle: "智能戒指端云协同健康辅助系统",
    period: "2024.11 至今",
    image: "/assets/vespero-status.png",
    alt: "VesperO 今日状态模块原型图",
    link: "https://github.com/SDLSY/Verspor",
    linkText: "GitHub 仓库",
    points: [
      "面向睡眠恢复与居家健康管理，连接 Android App、BLE 设备接入、睡眠与恢复分析、AI 问诊、医检报告理解、云端服务和后台管理。",
      "团队比赛项目；除视频制作外，核心开发、调试集成和材料整理主要由本人完成，最终获得全国大学生软件创新大赛全国三等奖。",
      "接入真实智能戒指硬件，并结合真实采集与演示数据完成多模态数据链路展示，覆盖 PPG、心率、血氧、体温、三轴加速度和三轴陀螺仪。"
    ],
    tags: ["Android", "BLE", "Next.js", "Supabase", "PPG/IMU"]
  },
  {
    id: "braille-imu",
    eyebrow: "科研潜力项目",
    title: "戒指式盲文触摸信号识别",
    subtitle: "基于 Hi90B 智能指环的 6 轴 IMU 时序识别",
    period: "2025.10 至今",
    image: "/assets/braille-signal.svg",
    alt: "IMU 时序信号示意图",
    link: "#braille-imu",
    linkText: "项目说明",
    points: [
      "在老师指导下推进，围绕 26 个英文盲文字母构建单被试初步实验数据集，每类不少于 100 组。",
      "搭建从 Android 采集、CSV 清洗、信号分段、特征提取到分类评估的流程，比较手工时序特征、ROCKET 系列方法和小波去噪等方案。",
      "严格时序划分下，当前单被试数据准确率由约 81% 提升到 87.2%；该结果不作为跨用户泛化结论。"
    ],
    tags: ["Wearable IMU", "Signal Processing", "Time Series", "Python"]
  }
];

const secondaryProjects = [
  {
    title: "AR 目标跟踪与虚实融合",
    text: "使用 ORB + RANSAC 完成特征点匹配、相机标定、3D 坐标变换和移动端实时渲染，达到 30FPS 虚实融合效果。",
    link: "https://github.com/SDLSY/BoxAR"
  },
  {
    title: "OceanBase / MiniOB 性能调优",
    text: "接触 B+ 树索引、LRU-K 缓冲池和并发控制机制，获得 OceanBase 大赛性能调优优胜。",
    link: ""
  }
];

const awards = [
  "全国大学生软件创新大赛全国三等奖",
  "全国大学生软件创新大赛华东赛区二等奖",
  "蓝桥杯 C++ 省一等奖",
  "全国大学生数学建模竞赛省级二等奖",
  "OceanBase 大赛性能调优优胜",
  "一等学业奖学金、二等学业奖学金、校级三好学生"
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="李上一，山东大学计算机科学与技术本科生，关注可穿戴计算、移动感知、健康计算与端侧智能。"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>李上一 | 山东大学计算机科学与技术</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="李上一个人主页">李上一</a>
      <nav class="nav" aria-label="页面导航">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#awards">Awards</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="kicker">山东大学 · 计算机科学与技术</p>
          <h1 id="hero-title">李上一</h1>
          <p class="lead">
            本科生，关注可穿戴计算、移动感知、健康计算与端侧智能，希望把智能戒指等可穿戴设备中的传感器数据转化为可靠、可解释的健康辅助能力。
          </p>
          <div class="interest-list" aria-label="研究兴趣">
            {interests.map((item) => <span>{item}</span>)}
          </div>
          <div class="actions" aria-label="常用链接">
            <a class="button primary" href="/cv.pdf">下载简历</a>
            <a class="button" href={github} target="_blank" rel="noreferrer">GitHub</a>
            <a class="button" href={`mailto:${email}`}>邮箱</a>
          </div>
        </div>
        <aside class="profile-panel" aria-label="快速信息">
          <div>
            <span class="metric-value">12 / 228</span>
            <span class="metric-label">专业成绩排名</span>
          </div>
          <div>
            <span class="metric-value">91.28</span>
            <span class="metric-label">GPA / 100</span>
          </div>
          <div>
            <span class="metric-value">2</span>
            <span class="metric-label">核心可穿戴项目</span>
          </div>
        </aside>
      </section>

      <section class="section" id="about" aria-labelledby="about-title">
        <p class="section-label">About</p>
        <h2 id="about-title">面向保研与科研交流的方向说明</h2>
        <p>
          我目前的主线是可穿戴计算、移动感知、健康计算与端侧智能：一方面做智能戒指健康辅助系统，积累 Android、BLE、端云协同与健康场景落地经验；另一方面尝试将戒指 IMU 信号用于盲文触摸动作识别，进一步训练时序信号建模与实验评估能力。
        </p>
      </section>

      <section class="section" id="projects" aria-labelledby="projects-title">
        <p class="section-label">Featured Projects</p>
        <h2 id="projects-title">核心项目</h2>
        <div class="project-list">
          {
            projects.map((project) => (
              <article class="project-card" id={project.id}>
                <div class="project-media">
                  <img src={project.image} alt={project.alt} loading="lazy" />
                </div>
                <div class="project-content">
                  <div class="project-meta">
                    <span>{project.eyebrow}</span>
                    <span>{project.period}</span>
                  </div>
                  <h3>{project.title}</h3>
                  <p class="project-subtitle">{project.subtitle}</p>
                  <ul>
                    {project.points.map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="tag-row">
                    {project.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                  <a class="text-link" href={project.link} target={project.link.startsWith("http") ? "_blank" : undefined} rel={project.link.startsWith("http") ? "noreferrer" : undefined}>
                    {project.linkText}
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        <div class="secondary-grid" aria-label="补充项目">
          {
            secondaryProjects.map((project) => (
              <article class="mini-project">
                <h3>{project.title}</h3>
                <p>{project.text}</p>
                {project.link && (
                  <a class="text-link" href={project.link} target="_blank" rel="noreferrer">查看仓库</a>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="awards" aria-labelledby="awards-title">
        <p class="section-label">Awards</p>
        <h2 id="awards-title">竞赛与荣誉</h2>
        <ul class="award-list">
          {awards.map((award) => <li>{award}</li>)}
        </ul>
      </section>

      <section class="section contact" id="contact" aria-labelledby="contact-title">
        <p class="section-label">Contact</p>
        <h2 id="contact-title">联系</h2>
        <p>欢迎围绕可穿戴计算、移动感知、健康计算、端侧智能与时序信号识别方向交流。</p>
        <div class="contact-links">
          <a href={`mailto:${email}`}>{email}</a>
          <a href={github} target="_blank" rel="noreferrer">github.com/SDLSY</a>
        </div>
      </section>
    </main>
  </body>
</html>
