---
import { profile } from "../data/profile.js";
import "../styles/global.css";

const emailHref = `mailto:${profile.email}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={`${profile.name}，${profile.school}${profile.major}本科生，关注可穿戴感知、健康管理智能体、端云协同与时序信号识别。`}
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{profile.name} | {profile.school}{profile.major}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${profile.name}个人主页`}>
        <img src="/assets/sdu-emblem.png" alt="" />
        <span>{profile.name}</span>
      </a>
      <nav class="nav" aria-label="页面导航">
        <a href="#profile">概况</a>
        <a href="#projects">项目</a>
        <a href="#skills">技能</a>
        <a href="#awards">荣誉</a>
        <a href="#contact">联系</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="school-line">{profile.school} · {profile.major}</p>
          <h1 id="hero-title">{profile.name}</h1>
          <p class="hero-lead">
            面向保研与科研交流，主线聚焦
            <strong>可穿戴感知、健康管理智能体、端云协同与时序信号识别</strong>。
            关注如何把戒指式可穿戴设备中的生理与惯性信号，转化为可解释、可追踪的健康辅助能力。
          </p>
          <div class="focus-strip" aria-label="项目主线">
            <span>项目主线</span>
            <p>{profile.focusLine}</p>
          </div>
          <div class="actions" aria-label="常用链接">
            <a class="button primary" href="/cv.pdf">下载简历</a>
            <a class="button" href="/intro/">在线 PPT</a>
            <a class="button" href="/files/li-shangyi-intro.pptx">下载 PPTX</a>
            <a class="button ghost" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
          </div>
        </div>
        <aside class="hero-panel" aria-label="快速信息">
          <img class="portrait" src="/assets/resume-photo-li-shangyi-red-bg-gpt-image-2.jpg" alt={`${profile.name}证件照`} />
          <div class="metric-grid">
            <div>
              <b>{profile.gpa}</b>
              <span>GPA</span>
            </div>
            <div>
              <b>{profile.rank}</b>
              <span>专业成绩排名（{profile.rankPercent}）</span>
            </div>
            <div>
              <b>2</b>
              <span>核心可穿戴项目</span>
            </div>
          </div>
        </aside>
      </section>

      <section class="section profile-section" id="profile" aria-labelledby="profile-title">
        <p class="section-label">Profile</p>
        <h2 id="profile-title">山东大学计算机科学与技术本科生</h2>
        <div class="profile-grid">
          <article>
            <h3>教育背景</h3>
            <p>{profile.college}，{profile.major}{profile.degree}，{profile.period}。</p>
            <p>英语：{profile.cet}</p>
          </article>
          <article>
            <h3>课程基础</h3>
            <p>{profile.courses.join("、")}。</p>
          </article>
          <article>
            <h3>方向定位</h3>
            <p>希望继续围绕可穿戴健康感知、移动端系统、端云协同和时序信号实验评估做深入训练。</p>
          </article>
        </div>
      </section>

      <section class="section" id="projects" aria-labelledby="projects-title">
        <p class="section-label">Projects</p>
        <h2 id="projects-title">核心项目经历</h2>
        <div class="project-list">
          {
            profile.projects.map((project, index) => (
              <article class={`project-card ${index % 2 === 1 ? "reverse" : ""}`} id={project.id}>
                <div class="project-media">
                  <img src={project.image} alt={project.imageAlt} loading="lazy" />
                </div>
                <div class="project-content">
                  <div class="project-meta">
                    <span>{project.label}</span>
                    <span>{project.period}</span>
                  </div>
                  <h3>{project.title}</h3>
                  <p class="project-subtitle">{project.subtitle}</p>
                  <ul>
                    {project.points.map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="tag-row">
                    {project.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="skills" aria-labelledby="skills-title">
        <p class="section-label">Skills</p>
        <h2 id="skills-title">技术能力结构</h2>
        <div class="skill-grid">
          {
            profile.skills.map((skill) => (
              <article>
                <h3>{skill.title}</h3>
                <p>{skill.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="awards" aria-labelledby="awards-title">
        <p class="section-label">Awards</p>
        <h2 id="awards-title">竞赛与荣誉</h2>
        <ul class="award-list">
          {profile.awards.map((award) => <li>{award}</li>)}
        </ul>
      </section>

      <section class="section contact" id="contact" aria-labelledby="contact-title">
        <p class="section-label">Contact</p>
        <h2 id="contact-title">联系与公开材料</h2>
        <p>欢迎围绕可穿戴计算、移动感知、健康计算、端云协同与时序信号识别方向交流。</p>
        <div class="contact-links">
          <a href={emailHref}>{profile.email}</a>
          <a href={profile.github} target="_blank" rel="noreferrer">{profile.githubText}</a>
          <a href="/cv.pdf">公开简历 PDF</a>
          <a href="/intro/">在线自我介绍</a>
        </div>
      </section>
    </main>
  </body>
</html>
