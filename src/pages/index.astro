---
import { profile } from "../data/profile.js";
import "../styles/global.css";

const emailHref = `mailto:${profile.email}`;
const projectCount = profile.projects.length.toString().padStart(2, "0");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={`${profile.name}的 Personal Lab：记录项目、笔记、时间线和公开材料，关注可穿戴感知、健康数据智能与移动端系统。`}
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{profile.name} | Personal Lab</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${profile.name} Personal Lab`}>
        <img src="/assets/sdu-emblem.png" alt="" />
        <span>{profile.name}</span>
      </a>
      <nav class="nav" aria-label="页面导航">
        <a href="#now">Now</a>
        <a href="#work">Work</a>
        <a href="#notes">Notes</a>
        <a href="#timeline">Timeline</a>
        <a href="#contact">Contact</a>
      </nav>
      <a class="header-link" href="/cv.pdf">CV</a>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <h1 id="hero-title">{profile.name}</h1>
          <p class="identity-line">{profile.identityLine}</p>
          <p class="hero-lead">{profile.intro}</p>
          <div class="hero-actions" aria-label="常用链接">
            <a class="button primary" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
            <a class="button" href={emailHref}>Email</a>
            <a class="button ghost" href="/cv.pdf">Download CV</a>
          </div>
        </div>

        <aside class="lab-console" aria-label="Lab Console">
          <div class="console-head">
            <img class="portrait" src="/assets/resume-photo-li-shangyi-red-bg-gpt-image-2.jpg" alt={`${profile.name}证件照`} />
            <div>
              <p>Personal Lab</p>
              <strong>{profile.englishName}</strong>
            </div>
          </div>
          <dl>
            {
              profile.labConsole.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))
            }
          </dl>
        </aside>
      </section>

      <section class="lab-strip" aria-label="Quick facts">
        <div>
          <span>GPA</span>
          <strong>{profile.gpa}</strong>
        </div>
        <div>
          <span>Rank</span>
          <strong>{profile.rank} · {profile.rankPercent}</strong>
        </div>
        <div>
          <span>Projects</span>
          <strong>{projectCount} featured works</strong>
        </div>
        <div>
          <span>Signals</span>
          <strong>{profile.focusTags.join(" / ")}</strong>
        </div>
      </section>

      <section class="section now-section" id="now" aria-labelledby="now-title">
        <div class="section-heading">
          <p>Now</p>
          <h2 id="now-title">What I am working on</h2>
        </div>
        <div class="now-grid">
          {
            profile.now.map((item) => (
              <article class="now-item">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section work-section" id="work" aria-labelledby="work-title">
        <div class="section-heading split">
          <div>
            <p>Featured Work</p>
            <h2 id="work-title">Projects as lab records</h2>
          </div>
          <a class="text-link" href={profile.github} target="_blank" rel="noreferrer">More on GitHub</a>
        </div>
        <div class="project-list">
          {
            profile.projects.map((project) => (
              <article class="project-record" id={project.id}>
                <div class="record-index">
                  <span>{project.label}</span>
                  <strong>{project.type}</strong>
                </div>
                <div class="record-media">
                  <img src={project.image} alt={project.imageAlt} loading="lazy" />
                </div>
                <div class="record-content">
                  <p class="record-period">{project.period}</p>
                  <h3>{project.title}</h3>
                  <p class="record-subtitle">{project.subtitle}</p>
                  <dl class="record-meta">
                    <div>
                      <dt>role</dt>
                      <dd>{project.role}</dd>
                    </div>
                    <div>
                      <dt>signal</dt>
                      <dd>{project.signal}</dd>
                    </div>
                    <div>
                      <dt>output</dt>
                      <dd>{project.output}</dd>
                    </div>
                  </dl>
                  <ul>
                    {project.points.slice(0, 3).map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="tag-row">
                    {project.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section notes-section" id="notes" aria-labelledby="notes-title">
        <div class="section-heading">
          <p>Lab Notes</p>
          <h2 id="notes-title">Ideas, readings, and engineering logs</h2>
        </div>
        <div class="note-list">
          {
            profile.notes.map((note) => (
              <article class="note-item">
                <span>{note.status}</span>
                <h3>{note.title}</h3>
                <p>{note.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section timeline-section" id="timeline" aria-labelledby="timeline-title">
        <div class="section-heading">
          <p>Timeline</p>
          <h2 id="timeline-title">A small archive of becoming</h2>
        </div>
        <ol class="timeline">
          {
            profile.timeline.map((item) => (
              <li>
                <time>{item.year}</time>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="section contact" id="contact" aria-labelledby="contact-title">
        <div class="contact-copy">
          <div class="section-heading">
            <p>Contact</p>
            <h2 id="contact-title">Let us build and learn in public</h2>
          </div>
          <p>
            欢迎围绕可穿戴计算、移动感知、健康数据智能、端云协同和时序信号识别交流。
          </p>
        </div>
        <div class="contact-links">
          <a href={emailHref}>{profile.email}</a>
          <a href={profile.github} target="_blank" rel="noreferrer">{profile.githubText}</a>
          <a href="/cv.pdf">CV PDF</a>
          <a href="/intro/">Intro Deck</a>
        </div>
      </section>
    </main>
  </body>
</html>
