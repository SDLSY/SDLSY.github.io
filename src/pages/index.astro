---
import { profile } from "../data/profile.js";
import "../styles/global.css";

const emailHref = `mailto:${profile.email}`;
const atlasNodes = [
  { key: "ring", label: "Ring", detail: "wearable input" },
  { key: "ble", label: "BLE", detail: "device link" },
  { key: "android", label: "Android", detail: "mobile client" },
  { key: "cloud", label: "Cloud", detail: "sync layer" },
  { key: "agent", label: "Agent", detail: "health loop" },
  { key: "imu", label: "IMU", detail: "time series" }
];
const atlasRoutes = [
  { number: "01", title: "可穿戴多源信号", text: "PPG / HR / SpO2 / IMU", tone: "red" },
  { number: "02", title: "戒指式触感信号", text: "6-axis IMU / touch actions", tone: "cyan" },
  { number: "03", title: "Android / BLE", text: "采集、解析、传输", tone: "blue" },
  { number: "04", title: "端云协同", text: "数据同步与健康代理", tone: "green" },
  { number: "05", title: "评估与反馈", text: "报告、建议、实验记录", tone: "violet" }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={`${profile.name}的 Sensor Atlas：以戒指式可穿戴信号、移动端采集、端云协同和健康智能体为主线的个人主页。`}
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{profile.name} | Sensor Atlas</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${profile.name} Sensor Atlas`}>
        <img src="/assets/sdu-emblem.png" alt="" />
        <span>{profile.name}</span>
      </a>
      <nav class="nav" aria-label="页面导航">
        <a href="#atlas">Atlas</a>
        <a href="#work">Work</a>
        <a href="#notes">Notes</a>
        <a href="#timeline">Timeline</a>
        <a href="#contact">Contact</a>
      </nav>
      <a class="header-link" href="/cv.pdf">CV</a>
    </header>

    <main>
      <section class="atlas-hero" id="atlas" aria-labelledby="hero-title">
        <div class="identity-rail">
          <p class="eyebrow">Sensor Atlas</p>
          <h1 id="hero-title">{profile.name}</h1>
          <p class="identity-line">{profile.identityLine}</p>
          <p class="hero-lead">{profile.intro}</p>
          <div class="hero-actions" aria-label="常用链接">
            <a class="button primary" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
            <a class="button" href={emailHref}>Email</a>
            <a class="button ghost" href="/cv.pdf">CV</a>
          </div>
          <dl class="hero-facts" aria-label="quick facts">
            <div>
              <dt>GPA</dt>
              <dd>{profile.gpa}</dd>
            </div>
            <div>
              <dt>Rank</dt>
              <dd>{profile.rank} · {profile.rankPercent}</dd>
            </div>
          </dl>
        </div>

        <div class="atlas-stage" aria-label="Interactive wearable signal atlas">
          <div class="atlas-title" aria-hidden="true">Sensor Atlas</div>
          <div class="atlas-scene" data-atlas-scene aria-hidden="true"></div>
          <div class="atlas-compass" aria-hidden="true">N</div>
          <div class="atlas-status" aria-hidden="true">
            <span>&gt; stream: ppg / imu / health</span>
            <span>&gt; route: ring → mobile → cloud → agent</span>
          </div>
          {
            atlasNodes.map((node) => (
              <div class={`atlas-node atlas-node-${node.key}`}>
                <span>{node.label}</span>
                <small>{node.detail}</small>
              </div>
            ))
          }
        </div>
      </section>

      <section class="atlas-routes" aria-labelledby="routes-title">
        <div class="section-heading">
          <p>Atlas Routes</p>
          <h2 id="routes-title">Projects as signal routes</h2>
        </div>
        <div class="route-map" aria-label="Project route map">
          {
            atlasRoutes.map((route) => (
              <article class={`route-stop route-stop-${route.tone}`}>
                <span>{route.number}</span>
                <strong>{route.title}</strong>
                <p>{route.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section work-section" id="work" aria-labelledby="work-title">
        <div class="section-heading split">
          <div>
            <p>Featured Work</p>
            <h2 id="work-title">Route logs from real builds</h2>
          </div>
          <a class="text-link" href={profile.github} target="_blank" rel="noreferrer">More on GitHub</a>
        </div>
        <div class="route-log-list">
          {
            profile.projects.map((project, index) => (
              <article class="route-log" id={project.id}>
                <div class="route-log-index">
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <strong>{project.type}</strong>
                </div>
                <div class="route-log-media">
                  <img src={project.image} alt={project.imageAlt} loading="lazy" />
                </div>
                <div class="route-log-content">
                  <p class="record-period">{project.period}</p>
                  <h3>{project.title}</h3>
                  <p class="record-subtitle">{project.subtitle}</p>
                  <dl class="record-meta">
                    <div>
                      <dt>role</dt>
                      <dd>{project.role}</dd>
                    </div>
                    <div>
                      <dt>signal</dt>
                      <dd>{project.signal}</dd>
                    </div>
                    <div>
                      <dt>output</dt>
                      <dd>{project.output}</dd>
                    </div>
                  </dl>
                  <ul>
                    {project.points.slice(0, 3).map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="tag-row">
                    {project.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section notes-section" id="notes" aria-labelledby="notes-title">
        <div class="section-heading">
          <p>Lab Notes</p>
          <h2 id="notes-title">Ideas, readings, and engineering logs</h2>
        </div>
        <div class="note-list">
          {
            profile.notes.map((note) => (
              <article class="note-item">
                <span>{note.status}</span>
                <h3>{note.title}</h3>
                <p>{note.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section timeline-section" id="timeline" aria-labelledby="timeline-title">
        <div class="section-heading">
          <p>Timeline</p>
          <h2 id="timeline-title">A small archive of sampled events</h2>
        </div>
        <ol class="sampling-line">
          {
            profile.timeline.map((item) => (
              <li>
                <time>{item.year}</time>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="section contact" id="contact" aria-labelledby="contact-title">
        <div class="contact-copy">
          <div class="section-heading">
            <p>Contact</p>
            <h2 id="contact-title">Let us build and learn in public</h2>
          </div>
          <p>欢迎围绕可穿戴计算、移动感知、健康数据智能、端云协同和时序信号识别交流。</p>
        </div>
        <div class="contact-terminal" aria-label="Contact links">
          <a href={emailHref}>{profile.email}</a>
          <a href={profile.github} target="_blank" rel="noreferrer">{profile.githubText}</a>
          <a href="/cv.pdf">CV PDF</a>
          <a href="/intro/">Intro Deck</a>
        </div>
      </section>
    </main>

    <script src="../scripts/sensor-atlas.js"></script>
  </body>
</html>
